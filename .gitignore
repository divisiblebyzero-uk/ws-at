# =========================================================================
# 📦 Vite / React Frontend Ignore Rules
# =========================================================================
node_modules/
dist/
.env*.local
.DS_Store
Thumbs.db

# =========================================================================
# 🤖 Capacitor Native Android Rules (Keep Configs, Drop Compiled Cruft)
# =========================================================================
# Ignore local Gradle caches and developer machine specific settings
android/.gradle/
android/local.properties
android/captures/
android/.idea/

# Ignore all compiled build outputs (keeps your repo light)
android/app/build/
android/build/

# Ignore the web asset mirroring directory 
# (Capacitor rebuilds this automatically when you run npx cap sync)
android/app/src/main/assets/public/